{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SageLang",
  "scopeName": "source.sage",
  "fileTypes": [
    "sage"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#module-names"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#member-access"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.number-sign.sage",
      "match": "#.*$"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sage",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.sage"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.sage"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.sage",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.sage",
          "begin": "'",
          "end": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.sage"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.sage"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.sage",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sage",
          "match": "(?<![\\w.])(?:\\d+\\.\\d+|\\d+\\.)(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.sage",
          "match": "(?<![\\w.])\\d+\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "begin": "\\b(from)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s+)(import)\\b",
          "end": "$",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.import.sage"
            },
            "2": {
              "name": "entity.name.namespace.sage"
            },
            "4": {
              "name": "keyword.control.import.sage"
            }
          },
          "patterns": [
            {
              "name": "constant.language.import.wildcard.sage",
              "match": "\\*"
            },
            {
              "name": "keyword.control.import.sage",
              "match": "\\b(as)\\b"
            },
            {
              "name": "variable.other.readwrite.import.sage",
              "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b"
            },
            {
              "name": "punctuation.separator.comma.sage",
              "match": ","
            }
          ]
        },
        {
          "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(as)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": {
              "name": "keyword.control.import.sage"
            },
            "2": {
              "name": "entity.name.namespace.sage"
            },
            "3": {
              "name": "keyword.control.import.sage"
            },
            "4": {
              "name": "entity.name.namespace.alias.sage"
            }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(async)(\\s+)(proc)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "storage.modifier.async.sage"
            },
            "3": {
              "name": "storage.type.function.sage"
            },
            "4": {
              "name": "entity.name.function.sage"
            }
          }
        },
        {
          "match": "\\b(proc)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "storage.type.function.sage"
            },
            "2": {
              "name": "entity.name.function.sage"
            }
          }
        },
        {
          "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*\\(\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*\\))?",
          "captures": {
            "1": {
              "name": "storage.type.class.sage"
            },
            "2": {
              "name": "entity.name.class.sage"
            },
            "3": {
              "name": "entity.other.inherited-class.sage"
            }
          }
        },
        {
          "match": "\\b(let|var)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.variable.sage"
            },
            "2": {
              "name": "variable.other.definition.sage"
            }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.sage",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.sage",
          "match": "\\bnil\\b"
        },
        {
          "name": "variable.language.self.sage",
          "match": "\\bself\\b"
        },
        {
          "name": "support.function.magic.sage",
          "match": "\\binit\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sage",
          "match": "\\b(if|elif|else|for|while|in|break|continue|return|print|try|catch|finally|raise|yield|defer|match|case|default|await)\\b"
        },
        {
          "name": "keyword.operator.logical.sage",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.sage",
          "match": "\\b(async|unsafe|import|from|as)\\b"
        }
      ]
    },
    "module-names": {
      "name": "support.type.module.sage",
      "match": "\\b(thread|io|sys|math|string|socket|tcp|http|ssl|json|arrays|strings|dicts|iter|stats|assert|utils)\\b"
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.sage",
          "match": "\\b(len|push|pop|range|split|join|replace|upper|lower|strip|slice|str|tonumber|input|clock|type|chr|ord|startswith|endswith|contains|indexof|dict_keys|dict_values|dict_has|dict_delete|gc_collect|gc_stats|gc_enable|gc_disable|next|ffi_open|ffi_call|ffi_sym|ffi_close|mem_alloc|mem_free|mem_read|mem_write|mem_size|addressof|asm_exec|asm_compile|asm_arch|struct_def|struct_new|struct_get|struct_set|struct_size)\\b(?=\\s*\\()"
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)\\s*([A-Z][A-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.other.object.sage"
            },
            "2": {
              "name": "punctuation.accessor.dot.sage"
            },
            "3": {
              "name": "constant.other.sage"
            }
          }
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "variable.other.object.sage"
            },
            "2": {
              "name": "punctuation.accessor.dot.sage"
            },
            "3": {
              "name": "support.function.member.sage"
            }
          }
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "variable.other.object.sage"
            },
            "2": {
              "name": "punctuation.accessor.dot.sage"
            },
            "3": {
              "name": "variable.other.property.sage"
            }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "match": "(?<!\\.)\\b(?!if\\b|elif\\b|else\\b|for\\b|while\\b|match\\b|case\\b|default\\b|proc\\b|class\\b|return\\b|try\\b|catch\\b|finally\\b|raise\\b|yield\\b|await\\b|print\\b|import\\b|from\\b|as\\b|let\\b|var\\b|and\\b|or\\b|not\\b)([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.sage"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.sage",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.sage",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.sage",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.sage",
          "match": "<<|>>|&|\\||\\^|~"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.parens.begin.sage",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.sage",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.sage",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.sage",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.braces.begin.sage",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.sage",
          "match": "\\}"
        },
        {
          "name": "punctuation.separator.colon.sage",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.sage",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.sage",
          "match": "\\."
        }
      ]
    }
  }
}
