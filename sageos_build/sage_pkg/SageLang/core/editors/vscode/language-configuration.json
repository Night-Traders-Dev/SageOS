{
  "comments": {
    "lineComment": "#"
  },
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*|\\d+(?:\\.\\d+)?",
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "{",
      "}"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:async\\s+proc|if|elif|else|for|while|proc|class|try|catch|finally|match|case|default)\\b[^#\\n]*:\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(?:elif|else|catch|finally|case|default)\\b.*:\\s*(#.*)?$"
  },
  "folding": {
    "offSide": true,
    "markers": {
      "start": "^\\s*(?:proc|class|if|elif|else|for|while|try|catch|finally|match|case|default)\\b[^#\\n]*:\\s*(#.*)?$",
      "end": "^\\s*$"
    }
  }
}
